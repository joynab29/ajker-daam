# Email — leave SMTP_HOST blank to auto-use Ethereal (free dev inbox; preview
# URLs are logged to the server console). For real delivery, pick one:
#
# Gmail (free, 500/day; needs an "App Password" with 2FA enabled):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_16_char_app_password
#
# Brevo / Sendinblue (free, 300/day; sign up + grab SMTP key):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your_brevo_login
#   SMTP_PASS=your_brevo_smtp_key
#
# MAIL_FROM=Ajker Daam <no-reply@yourdomain.com>
